# ── Colleague-owned services (LLM/Agent, TTS, ASR) ─────────────
# Point at the in-repo mock agent for local dev; swap to production URLs when ready.
NEXT_PUBLIC_AGENT_URL=http://localhost:8787
NEXT_PUBLIC_ASR_URL=

# Optional: separate TTS endpoint. If empty, TTS audio is expected inline
# on the agent SSE stream as `audio_chunk` events (recommended).
NEXT_PUBLIC_TTS_URL=

# ── Mock banking API (this app) ────────────────────────────────
# Shared secret the agent sends in `X-Bushra-Mock-Key` when calling /api/bank/*.
BUSHRA_MOCK_BANK_KEY=dev-secret-change-me

# Origin allowed to call /api/bank/* (the agent service). Comma-separated.
BUSHRA_AGENT_ORIGIN=http://localhost:8787
